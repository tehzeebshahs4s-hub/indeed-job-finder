# Core
DATABASE_URL=sqlite:///./indeed.db
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# App
APP_ENV=dev
APP_DEBUG=true

# Scraper
SCRAPER_HEADLESS=true
SCRAPER_MIN_DELAY=3
SCRAPER_MAX_DELAY=8
SCRAPER_CACHE_TTL_SECONDS=3600
SCRAPER_TIMEOUT_SECONDS=30
# Set to false on low-memory (free) tiers where Chromium can't run.
INDEED_ENABLED=true

# Fallback job APIs (register free accounts)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JOOBLE_API_KEY=

# 2Captcha (paid CAPTCHA solver)
TWO_CAPTCHA_KEY=
CAPTCHA_DAILY_LIMIT=50
